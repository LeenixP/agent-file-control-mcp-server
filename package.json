{
  "name": "agent-file-control-mcp-server",
  "version": "1.1.1",
  "description": "MCP server for complete file control with base64 encoding to bypass JSON parsing issues",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "agent-file-control": "dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "clean": "rm -rf dist"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.6.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "keywords": [
    "mcp",
    "mcp-server",
    "file-control",
    "base64",
    "model-context-protocol",
    "ai-agent"
  ],
  "author": "LeenixP",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LeenixP/agent-file-control-mcp-server.git"
  },
  "homepage": "https://github.com/LeenixP/agent-file-control-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/LeenixP/agent-file-control-mcp-server/issues"
  }
